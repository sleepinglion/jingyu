<article class="galleries col-12" data-controller="hello">
  <h3><%= t(:gallery,scope: [:activerecord,:models]) %></h3>
  <div class="row">
    <% @galleries.each do |gallery| %>
      <%= link_to image_tag(gallery.photo.medium_thumb.url,width: "100%",loading: 'lazy', alt: gallery.title) , gallery_path(gallery), class: "col-6 col-md-4 col-xl-3 col-xxl-2 mb-3" %>
    <% end %>
  </div>
  <%=link_to t(:link_more),galleries_path,:class=>'more' %>
</article>
