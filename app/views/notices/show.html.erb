<% breadcrumb :notice,@notice %>
<article id="sl_notice_show">
  <div class="slboard_content">
    <div class="sl_content_header">
      <h3><%= @notice.title %></h3>
      <p><%=t(:label_name)%> : <span><%=userName(@notice,10) %></span>&nbsp;&nbsp;&nbsp; <%=t(:label_created_at)%> : <span><%= l(@notice.created_at.to_date, format: :long) %></span></p>
    </div>
    <div class="sl_content_main">
      <div class="sl_content_text"><%=simple_format @notice.content %></div>
    </div>
  </div>
  <div class="row">
    <div class="btn-group btn-group-lg col-12" role="group" style="margin-top:3rem">
      <%=link_to t(:link_list),notices_path,{class: 'btn btn-secondary btn-large btn-block'} %>
    </div>
  </div>
</article>
<% content_for :json_ld do %>
  <script type="application/ld+json">
    <%= raw(JSON.pretty_generate(json_ld_for_notice(@notice))) %>
  </script>
<% end %>
